# ===================================
# CONFIGURAÇÃO DE SEGURANÇA - FOOD SYSTEM
# ===================================
# ⚠️ NUNCA committar este arquivo
# ⚠️ Adicione .env ao .gitignore

# --- BACKEND CORE ---
PORT=8000
NODE_ENV=development

# --- DATABASE (ALTERE AS CREDENCIAIS!) ---
# Gerar senha: openssl rand -base64 20
DATABASE_URL=postgresql://app_user:GereSenhaForteLongo32Caracteres@localhost:5432/food_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=GereSenhaForteLongo32Caracteres
POSTGRES_DB=food_db

# --- JWT (Gerar com: openssl rand -base64 32) ---
JWT_SECRET=SeuSecretJWTAleatorio32CaracteresAqui

# --- FRONTEND ---
FRONTEND_URL=http://localhost:3000

# --- SECURITY - CORS ---
# Separar múltiplos origins com vírgula
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# --- ADMIN INICIAL (remova após primeira execução!) ---
# Use para criar o primeiro super admin
INITIAL_ADMIN_PASSWORD=TemporariaPass@2026

# --- OPCIONAL: Email/Notificações ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASSWORD=sua-senha-app

# --- RATE LIMITING ---
# Máximo de requisições por IP por janela (15 min padrão)
RATE_LIMIT_MAX=100

# --- LOGS ---
LOG_LEVEL=info
