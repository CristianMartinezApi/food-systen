generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plan {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  tier        PlanTier     @default(FREE)
  price       Float
  maxProducts Int          @default(10)
  maxOrders   Int          @default(100)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  restaurants Restaurant[]

  @@map("plans")
}

model Restaurant {
  id                 Int        @id @default(autoincrement())
  name               String
  slug               String     @unique
  logo               String?
  description        String?
  phone              String?
  isActive           Boolean    @default(true)
  provisioningStatus String     @default("PENDING")
  databaseName       String?
  planId             Int?
  subscriptionStatus String     @default("active")
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  categories         Category[]
  customers          Customer[]
  orders             Order[]
  products           Product[]
  plan               Plan?      @relation(fields: [planId], references: [id])
  settings           Settings?
  users              User[]
  provisioningLogs   ProvisioningLog[]

  @@map("restaurants")
}

model ProvisioningLog {
  id           Int      @id @default(autoincrement())
  restaurantId Int
  message      String
  level        String   @default("info")
  createdAt    DateTime @default(now())

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model User {
  id           Int         @id @default(autoincrement())
  name         String
  email        String      @unique
  password     String
  role         UserRole    @default(OWNER)
  isApproved   Boolean     @default(false)
  isActive     Boolean     @default(true)
  restaurantId Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  auditLogs    AuditLog[]

  @@index([restaurantId])
  @@map("users")
}

model Customer {
  id           Int        @id @default(autoincrement())
  name         String
  phone        String?
  email        String?
  restaurantId Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@index([restaurantId])
  @@map("customers")
}

model Category {
  id           Int        @id @default(autoincrement())
  name         String
  slug         String
  order        Int        @default(0)
  isActive     Boolean    @default(true)
  restaurantId Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([restaurantId, slug])
  @@unique([id, restaurantId])
  @@index([restaurantId])
  @@map("categories")
}

model Product {
  id           Int         @id @default(autoincrement())
  name         String
  description  String?
  price        Float
  image        String?
  isActive     Boolean     @default(true)
  isFeatured   Boolean     @default(false)
  discountPercent Float    @default(0)
  restaurantId Int
  categoryId   Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  addons       Json?
  ingredients  Json?
  sizes        Json?
  orderItems   OrderItem[]
  category     Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([id, restaurantId])
  @@index([restaurantId])
  @@index([categoryId])
  @@map("products")
}

model Order {
  id            Int           @id @default(autoincrement())
  customerName  String
  phone         String?
  address       Json?
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  subtotal      Float
  deliveryFee   Float         @default(0)
  total         Float
  notes         String?
  restaurantId  Int
  customerId    Int?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  changeFor     String?
  cpf           String?
  items         OrderItem[]
  customer      Customer?     @relation(fields: [customerId], references: [id])
  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([customerId])
  @@map("orders")
}

model OrderItem {
  id           Int      @id @default(autoincrement())
  orderId      Int
  productId    Int
  quantity     Int
  price        Float
  createdAt    DateTime @default(now())
  addons       Json?
  name         String?
  observations String?
  removals     Json?
  variation    String?
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Settings {
  id             Int        @id @default(autoincrement())
  restaurantId   Int        @unique
  storeName      String
  bio            String?
  phone          String?
  address        String?
  bannerBadge    String?
  bannerTitleLine1 String?
  bannerTitleLine2 String?
  bannerDescription String?
  bannerCtaLabel String?
  bannerImage    String?
  deliveryFee    Float      @default(5)
  minOrderValue  Float      @default(20)
  deliveryEtaMinutes Int    @default(35)
  isOpen         Boolean    @default(true)
  primaryColor   String     @default("#ef4444")
  logo           String?
  instagram      String?
  facebook       String?
  operatingHours Json?
  latitude       Float?
  longitude      Float?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deliveryRadius Float?     @default(5)
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("settings")
}

enum PlanTier {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  MANAGER
  EMPLOYEE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  PIX
  CASH
  CARD
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  actorId     Int?
  actorEmail  String?
  action      String
  subjectType String
  subjectId   Int?
  details     Json?
  createdAt   DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@map("audit_logs")
}
