# Ambiente de produção — Exemplo
# NÃO commite este arquivo com segredos reais.

# --- BACKEND CORE ---
PORT=8000
NODE_ENV=production

# --- DATABASE (ajuste conforme seu provedor) ---
# Para Postgres em container: postgres://user:pass@db:5432/food_db
DATABASE_URL=postgresql://app_user_prod:SenhaForteAqui@db:5432/food_db
POSTGRES_USER=app_user_prod
POSTGRES_PASSWORD=SenhaForteAqui
POSTGRES_DB=food_db

# --- JWT (gere com openssl rand -base64 32) ---
JWT_SECRET=GereUmJWTSecretBase64Aqui

# --- FRONTEND / SOCKET ---
FRONTEND_URL=https://seu-dominio.com
NEXT_PUBLIC_API_URL=https://seu-dominio.com/api
NEXT_PUBLIC_SOCKET_URL=https://seu-dominio.com

# --- CORS ---
ALLOWED_ORIGINS=https://seu-dominio.com,https://www.seu-dominio.com

# --- SENHAS INICIAIS (remova ou esvazie após primeira execução) ---
INITIAL_ADMIN_PASSWORD=
INITIAL_SUPERADMIN_PASSWORD=

# --- RATE LIMITING ---
RATE_LIMIT_MAX=100

# --- LOGS ---
LOG_LEVEL=info

# --- SMTP (opcional) ---
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=

# --- SENTRY / ANALYTICS (opcional) ---
# SENTRY_DSN=

# -----------------------------
# Instruções rápidas:
# 1) Gere segredos locais (exemplos):
#    openssl rand -base64 20  # senha DB
#    openssl rand -base64 32  # JWT_SECRET
# 2) Copie este arquivo para a VPS e renomeie para `.env` na raiz do repositório.
#    Exemplo (no seu PC): scp deploy/.env.production.example root@191.252.110.216:/root/food-systen/.env
# 3) No VPS: verifique permissões e rode o bootstrap:
#    ssh root@191.252.110.216
#    cd /root/food-systen
#    sudo bash deploy/bootstrap-vps.sh seu-dominio.com
# 4) Não commite `.env`. Use secrets manager se disponível.
