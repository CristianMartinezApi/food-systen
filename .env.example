# ===================================
# FOOD SYSTEM - VARIÁVEIS DE AMBIENTE
# ===================================
# ⚠️ NUNCA committar este arquivo no Git!
# ⚠️ Adicione .env ao .gitignore

# --- BACKEND CORE ---
PORT=8000
NODE_ENV=development

# --- DATABASE (ALTERE AS CREDENCIAIS!) ---
# Gerar PASSWORD com: openssl rand -base64 20
DATABASE_URL=postgresql://app_user_dev:SenhaForteAleatoriaAqui123456@localhost:5432/food_db
POSTGRES_USER=app_user_dev
POSTGRES_PASSWORD=SenhaForteAleatoriaAqui123456
POSTGRES_DB=food_db

# --- JWT (Gerar com: openssl rand -base64 32) ---
# Exemplo: VhMWRzQmL0gJ2x1fXQw0dz5K8vL3pQ+rR9sY2uN5aB8=
JWT_SECRET=GereSeuSecretJWTAleatorio32CaracteresAquiUsandoOpenSSL

# --- FRONTEND URL ---
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:8000

# --- SECURITY - CORS ---
# Separar múltiplos origins com vírgula
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://seudominio.com

# --- SENHAS INICIAIS (USE APENAS NA PRIMEIRA EXECUÇÃO) ---
# Deixe em branco após primeira execução para gerar senhas aleatórias
INITIAL_ADMIN_PASSWORD=AdminTemporario@2026
INITIAL_SUPERADMIN_PASSWORD=SuperAdminTemporario@2026

# --- RATE LIMITING ---
RATE_LIMIT_MAX=100

# --- LOGS ---
LOG_LEVEL=info

# --- OPCIONAL: Email/Notificações ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASSWORD=sua-senha-app-specific

# --- OPCIONAL: Analytics ---
# SENTRY_DSN=https://seu-sentry-dsn@sentry.io/project-id
